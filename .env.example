# PDF の場所
# 例: ./data/books
# WSL / Windows では /mnt/c/Users/<name>/... のような絶対パスも使えます。
BOOKS_DIR=./data/books

# SQLite DB の保存先ディレクトリ
DB_DIR=./data

# PDF切り出し保存先フォルダ
# 例: /mnt/c/Users/<name>/Google Drive/NotebookLM
PDF_EXPORT_SAVE_DIR=

# Web UI の公開ポート
WEB_PORT=8000

# Scrapbox を使う場合のベースURL
# 例: https://scrapbox.io/<your_project_name>
SCRAPBOX_BASE_URL=

# Scrapbox エクスポートJSONの場所
# 例: ./shino-books_imported.json
SCRAPBOX_EXPORT_JSON=
